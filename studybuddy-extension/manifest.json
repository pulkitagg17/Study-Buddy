{
  "name": "StudyBuddy Extension",
  "description": "AI Interviewer, Mentor & Motivator Sidebar",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_title": "StudyBuddy"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:4000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "styles.css",
        "sidebar.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
